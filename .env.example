# Copy to .env and fill in whichever provider key you have.
# Only ONE is needed - the extraction backend is chosen at adapter-wiring time.
# The whole pipeline also runs with NO key via the fixture/replay backend.

GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
# ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE
# MOONSHOT_API_KEY=YOUR_KIMI_API_KEY_HERE     # Kimi K2.6 (OpenAI-compatible)
# OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
